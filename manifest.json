{
  "manifest_version": 3,
  "name": "Claude Auto-Primer",
  "version": "1.3.0",
  "description": "Automatically sends a primer message when opening a new Claude.ai chat.",
  "homepage_url": "https://github.com/oldgitimh/claude-auto-primer",
  "permissions": ["storage"],
  "icons": {
    "16": "icon16.png",
    "32": "icon32.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["https://claude.ai/*"],
      "js": ["shared.js", "content.js"],
      "run_at": "document_end"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "32": "icon32.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  }
}
